{
  "name": "oss-maintainer-kit",
  "version": "0.2.0",
  "description": "Turn a code repository into a contributor-friendly public project with clear GitHub workflows.",
  "type": "module",
  "bin": "bin/maintainer-kit.js",
  "files": [
    "bin",
    "src",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test",
    "check": "node --test",
    "pack:check": "npm pack --dry-run",
