{
  "name": "oss-maintainer-kit",
  "version": "0.12.0",
  "description": "Turn a code repository into a contributor-friendly public project with clear GitHub workflows.",
  "type": "module",
  "bin": {
    "oss-maintainer-kit": "bin/maintainer-kit.js"
  },
  "files": [
    "bin",
    "manifests",
    "src",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test",
    "check": "node --test",
    "pack:check": "npm pack --dry-run",
    "docs:check": "node ./bin/maintainer-kit.js check-docs .",
    "demo:render": "python3 ./scripts/render_demo_gif.py",
    "previews:render": "python3 ./scripts/render_example_social_previews.py"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BlakeHampson/oss-maintainer-kit.git"
  },
  "homepage": "https://github.com/BlakeHampson/oss-maintainer-kit#readme",
  "bugs": {
    "url": "https://github.com/BlakeHampson/oss-maintainer-kit/issues"
  },
  "keywords": [
    "open-source",
    "starter-kit",
    "cli",
    "github",
    "github-actions",
    "codex",
    "agents-md",
    "automation",
    "maintainers",
    "labels",
    "triage",
    "npx",
    "security"
  ],
  "author": "Blake Hampson",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
